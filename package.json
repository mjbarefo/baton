{
  "name": "baton",
  "version": "0.1.0",
  "description": "Context-aware session baton for Claude Code. Statusline + /baton + PreCompact safety net.",
  "type": "module",
  "engines": {
    "bun": ">=1.3"
  },
  "bin": {
    "baton": "./dist/baton"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/baton",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "files": [
    "src",
    "dist"
  ],
  "keywords": ["claude-code", "statusline", "baton", "context", "anthropic"]
}
